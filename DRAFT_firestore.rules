rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.sku is string && data.sku.size() > 0 && data.sku.size() <= 64 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() <= 100 &&
             data.quantity is number && data.quantity >= 0 &&
             data.instock is bool;
    }

    function isValidOrder(data) {
      return data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.totalAfterDiscount is number && data.totalAfterDiscount >= 0 &&
             data.status in ['new', 'processed'] &&
             data.created is timestamp && data.created == request.time;
    }

    function isValidUser(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'customer'];
    }

    // --- Collection Rules ---

    // Products: Public read, Admin write
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Vehicles: Public read, Admin write
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Orders: Owner create/read, Admin read/update/delete
    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isEmailVerified() && isValidOrder(incoming());
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['new', 'processed']
      );
      allow delete: if isAdmin();
    }

    // Users: Owner read/write, Admin read/write
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if isSignedIn() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'address']) && isValidUser(incoming())) ||
        isAdmin()
      );
    }
  }
}
